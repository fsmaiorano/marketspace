@BackendForFrontend_HostAddress = http://localhost:4000

### Health Check
GET {{BackendForFrontend_HostAddress}}/swagger
Accept: application/json

### === AUTH ===

### Register
POST {{BackendForFrontend_HostAddress}}/api/auth/register
Content-Type: application/json

{
  "email": "user@example.com",
  "password": "Password123!",
  "confirmPassword": "Password123!"
}

###

### Login
POST {{BackendForFrontend_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "user@example.com",
  "password": "Password123!"
}

###

### Me
GET {{BackendForFrontend_HostAddress}}/api/auth/me
Accept: application/json
Authorization: Bearer {{accessToken}}

###

### Refresh Token
POST {{BackendForFrontend_HostAddress}}/api/auth/refresh
Content-Type: application/json

{
  "accessToken": "{{accessToken}}",
  "refreshToken": "{{refreshToken}}"
}

###

### Revoke Token
POST {{BackendForFrontend_HostAddress}}/api/auth/revoke
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "refreshToken": "{{refreshToken}}"
}

###

### Update User Type
PATCH {{BackendForFrontend_HostAddress}}/api/auth/update-user-type
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "userType": 1
}

###

### === MERCHANT ===

### Create Merchant
POST {{BackendForFrontend_HostAddress}}/api/merchant
Content-Type: application/json

{
  "name": "Test Merchant",
  "description": "A test merchant for BFF",
  "address": "123 Main St, City, State",
  "phoneNumber": "555-1234",
  "email": "test@merchant.com"
}

###

### Get Merchant by ID
GET {{BackendForFrontend_HostAddress}}/api/merchant/{{$guid}}
Accept: application/json

###

### Get My Merchant
GET {{BackendForFrontend_HostAddress}}/api/merchant/me
Accept: application/json
Authorization: Bearer {{accessToken}}

###

### Update Merchant
PUT {{BackendForFrontend_HostAddress}}/api/merchant/{{$guid}}
Content-Type: application/json

{
  "name": "Updated Merchant",
  "description": "Updated description",
  "address": "456 Updated St",
  "phoneNumber": "555-5678",
  "email": "updated@merchant.com"
}

###

### Delete Merchant
DELETE {{BackendForFrontend_HostAddress}}/api/merchant/{{$guid}}

###

### === CATALOG ===

### Create Catalog Item
POST {{BackendForFrontend_HostAddress}}/api/catalog
Content-Type: application/json

{
  "name": "Test Product",
  "description": "A test product for catalog",
  "price": 29.99,
  "category": "Electronics",
  "summary": "Test product summary",
  "imageFile": "test-product.jpg"
}

###

### Get Catalog List
GET {{BackendForFrontend_HostAddress}}/api/catalog
Accept: application/json

###

### Get Catalog Item by ID
GET {{BackendForFrontend_HostAddress}}/api/catalog/{{$guid}}
Accept: application/json

###

### Get Catalog by Merchant
GET {{BackendForFrontend_HostAddress}}/api/catalog/merchant/{{$guid}}
Accept: application/json

###

### Update Catalog Item
PUT {{BackendForFrontend_HostAddress}}/api/catalog/{{$guid}}
Content-Type: application/json

{
  "name": "Updated Product",
  "description": "Updated description",
  "price": 39.99
}

###

### Update Stock
PATCH {{BackendForFrontend_HostAddress}}/api/catalog/{{$guid}}/stock
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "quantity": 50
}

###

### Delete Catalog Item
DELETE {{BackendForFrontend_HostAddress}}/api/catalog/{{$guid}}

###

### === BASKET ===

### Create Basket
POST {{BackendForFrontend_HostAddress}}/api/basket
Content-Type: application/json

{
  "username": "testuser",
  "items": [
    {
      "quantity": 2,
      "price": 29.99,
      "productId": "{{$guid}}",
      "productName": "Test Product"
    }
  ]
}

###

### Get Basket
GET {{BackendForFrontend_HostAddress}}/api/basket/testuser
Accept: application/json

###

### Checkout Basket
POST {{BackendForFrontend_HostAddress}}/api/basket/checkout
Content-Type: application/json

{
  "userName": "testuser",
  "customerId": "{{$guid}}",
  "totalPrice": 59.98
}

###

### Delete Basket
DELETE {{BackendForFrontend_HostAddress}}/api/basket/testuser

###

### === ORDER ===

### Create Order
POST {{BackendForFrontend_HostAddress}}/api/order
Content-Type: application/json

{
  "customerId": "{{$guid}}",
  "shippingAddress": {
    "firstName": "John",
    "lastName": "Doe",
    "emailAddress": "john.doe@email.com",
    "addressLine": "123 Main St",
    "country": "USA",
    "state": "CA",
    "zipCode": "12345"
  },
  "billingAddress": {
    "firstName": "John",
    "lastName": "Doe",
    "emailAddress": "john.doe@email.com",
    "addressLine": "123 Main St",
    "country": "USA",
    "state": "CA",
    "zipCode": "12345"
  },
  "payment": {
    "cardName": "John Doe",
    "cardNumber": "1234567890123456",
    "expiration": "12/25",
    "cvv": "123",
    "paymentMethod": 1
  },
  "items": [
    {
      "productId": "{{$guid}}",
      "quantity": 2,
      "price": 29.99
    }
  ]
}

###

### Get Order by ID
GET {{BackendForFrontend_HostAddress}}/api/order/{{$guid}}
Accept: application/json

###

### Get Orders by Customer
GET {{BackendForFrontend_HostAddress}}/api/order/customer/{{$guid}}
Accept: application/json

###

### Update Order
PUT {{BackendForFrontend_HostAddress}}/api/order/{{$guid}}
Content-Type: application/json

{
  "orderName": "Updated Order"
}

###

### Delete Order
DELETE {{BackendForFrontend_HostAddress}}/api/order/{{$guid}}

###

### === AI ===

### Chat
POST {{BackendForFrontend_HostAddress}}/api/ai/chat
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "message": "What products do you sell?",
  "userId": "{{$guid}}"
}

###

### Ask with RAG
POST {{BackendForFrontend_HostAddress}}/api/ai/rag
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "question": "How does the order process work?",
  "contextId": "marketplace"
}

###

### Agent (order status lookup)
POST {{BackendForFrontend_HostAddress}}/api/ai/agent
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "message": "What is the status of order {{$guid}}?",
  "userId": "{{$guid}}"
}

###
